{
  "name": "backlog-gardener",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first agent for surfacing actionable backlog and review signals.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "bin": {
    "gardener": "./dist/gardener/cli.js",
    "gardener-github-app": "./dist/gardener/app/server.js"
  },
  "scripts": {
    "gardener": "tsx src/gardener/cli.ts",
    "gardener:github-app": "tsx src/gardener/app/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" vitest.config.ts",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" vitest.config.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "openai": "^6.35.0",
    "rss-parser": "^3.13.0",
    "sanitize-html": "^2.17.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  }
}
