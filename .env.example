# Copy to .env and fill in values for local runs.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# GitHub App server credentials. `pnpm gardener github-app exchange-code <code>` can write these to .env.
GARDENER_APP_ID=
GARDENER_APP_PRIVATE_KEY=
GARDENER_APP_WEBHOOK_SECRET=
GARDENER_APP_STATE_PATH=.gardener-state/app.db

# Optional: omit or leave blank to skip Slack publishing.
SLACK_WEBHOOK_URL=
